{
  "name": "tetris",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "prisma generate && react-router build",
    "db:generate": "prisma generate",
    "db:migrate": "tsx scripts/init-db.ts",
    "db:push": "tsx scripts/init-db.ts",
    "db:studio": "prisma studio",
    "dev": "react-router dev",
    "postinstall": "prisma generate",
    "start": "react-router-serve ./build/server/index.js",
    "test": "vitest run",
    "typecheck": "react-router typegen && tsc"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@react-router/node": "7.13.1",
    "@react-router/serve": "7.13.1",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "isbot": "^5.1.31",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "7.13.1"
  },
  "devDependencies": {
    "@react-router/dev": "7.13.1",
    "@react-router/fs-routes": "7.13.1",
    "@tailwindcss/vite": "^4.1.13",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "prisma": "^7.4.2",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
