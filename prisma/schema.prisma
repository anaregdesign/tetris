generator client {
  provider = "prisma-client"
  output   = "../app/lib/server/infrastructure/generated/prisma"
}

datasource db {
  provider = "sqlserver"
}

model User {
  id          String     @id @default(cuid()) @db.VarChar(30)
  githubId    String     @unique @db.VarChar(64)
  handle      String     @db.VarChar(39)
  displayName String     @db.NVarChar(255)
  avatarUrl   String?    @db.VarChar(2048)
  profileUrl  String?    @db.VarChar(2048)
  email       String?    @db.VarChar(320)
  createdAt   DateTime   @default(now()) @db.DateTime2
  updatedAt   DateTime   @updatedAt @db.DateTime2
  scoreRuns   ScoreRun[]
}

model ScoreRun {
  id         String   @id @default(cuid()) @db.VarChar(30)
  userId     String   @db.VarChar(30)
  score      Int
  lines      Int
  level      Int
  durationMs Int
  recordedAt DateTime @default(now()) @db.DateTime2
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt])
  @@index([score, recordedAt])
}
